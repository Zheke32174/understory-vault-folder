    <queries>
        <package android:name="com.understory.passgen" />
        <package android:name="com.understory.aegis" />
        <package android:name="com.understory.firewall" />
        <package android:name="com.understory.backups" />
        <package android:name="com.understory.browser" />
        <package android:name="com.understory.antivirus" />
        <package android:name="com.chelpus.lackypatch" />
        <package android:name="com.dimonvideo.luckypatcher" />
        <package android:name="com.forpda.lp" />
        <package android:name="com.android.vending.billing.InAppBillingService.LUCK" />
        <package android:name="com.android.vending.billing.InAppBillingService.LACK" />
        <package android:name="ru.aaaaaaac.luckypatcher" />
        <package android:name="uret.jasi2169.patcher" />
        <package android:name="zone.jasi2169.uretpatcher" />
        <package android:name="ru.luckypatchers.luckypatcherinstaller" />
        <package android:name="de.robv.android.xposed.installer" />
        <package android:name="org.meowcat.edxposed.manager" />
        <package android:name="org.lsposed.manager" />
        <package android:name="io.github.lsposed.manager" />
        <package android:name="com.topjohnwu.magisk" />
        <package android:name="io.github.huskydg.magisk" />
        <package android:name="com.kingoapp.apk" />
        <package android:name="com.koushikdutta.rommanager" />
        <package android:name="eu.chainfire.supersu" />
    </queries>

    <application
        android:label="@string/app_name"
        android:icon="@mipmap/ic_launcher"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:theme="@style/Theme.VaultFolder"
        android:allowBackup="false"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="false"
        android:networkSecurityConfig="@xml/network_security_config"
        android:usesCleartextTraffic="false"
        android:supportsRtl="true">

        <!--
          Vault UI activity. excludeFromRecents keeps vault contents out
          of the recents thumbnail; FLAG_SECURE + setRecentsScreenshotEnabled
          (MainActivity.initialize) back it at runtime. resizeableActivity is
          true and there is no portrait lock — the screens are simple reflowing
          Column/LazyColumn layouts and the in-app viewer benefits from
          landscape; configChanges below absorbs the rotation with no state loss.
        -->
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:launchMode="singleTask"
            android:excludeFromRecents="true"
            android:resizeableActivity="true"
            android:configChanges="orientation|screenSize|keyboardHidden|uiMode"
            android:theme="@style/Theme.VaultFolder">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
            <!--
              Cross-app deposit intent-filter. Lets any app on the device
              hand vault-folder a file via Android's standard "Open with…"
              dialog (or via Intent.setPackage from a peer suite app),
              with the URI grant carrying read permission for the
              activity lifetime. The user, not an automated dispatcher,
              accepts each deposit: vault-folder still requires biometric
              unlock and shows a confirmation before encrypting the
              incoming file into the vault. No code path bypasses either
              gate.

              The MIME list is broad so suite-app exports (encrypted
              envelopes as octet-stream, JSON exports, plain-text dumps)
              all match. Non-suite apps can deposit too — vault-folder
              treats every incoming URI the same: read via SAF, encrypt
              into the vault, surface in the file list.
            -->
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <data android:mimeType="application/octet-stream" />
                <data android:mimeType="application/json" />
                <data android:mimeType="text/plain" />
                <data android:mimeType="text/csv" />
                <data android:mimeType="image/*" />
                <data android:mimeType="application/pdf" />
            </intent-filter>
        </activity>

        <!--
          In-app viewer's isolated renderer (§5.2). isolatedProcess=true runs it
          in a sandbox with no permissions, no Keystore, no filesystem, no
          network; exported=false keeps it private to this app. It only ever
          receives already-decrypted bytes over an in-memory pipe and returns a
          rendered bitmap, so a malformed-image/PDF parser bug can't reach the
          KEK or the blobs.
        -->
        <service
            android:name=".ViewerRenderService"
            android:isolatedProcess="true"
            android:exported="false" />

        <provider
            android:name=".SuiteCapsProvider"
            android:authorities="${applicationId}.suitecaps"
            android:exported="true"
            android:readPermission="com.understory.suite.CAPS"
            android:writePermission="com.understory.suite.CAPS_WRITE"
            android:grantUriPermissions="false" />

    </application>

</manifest>
